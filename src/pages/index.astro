---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { homeHero, oldPosts } from "../data/site";
import { getFeaturedNotes, getLatestNotes, getNoteSummary, getPublishedNotes } from "../utils/content";
import { getSearchIndex } from "../utils/search";

const allNotes = await getCollection("notes");
const notes = getPublishedNotes(allNotes);
const searchIndex = getSearchIndex(notes);
const featuredBase = getFeaturedNotes(notes, 3);
const featuredFill = getLatestNotes(notes, 3, { excludeIds: featuredBase.map((note) => note.id) });
const featuredNotes = [...featuredBase, ...featuredFill].slice(0, 3);
const latestNotes = getLatestNotes(notes, 4, { excludeIds: featuredNotes.map((note) => note.id) });
const leadFeatured = featuredNotes[0];
const sideFeatured = featuredNotes.slice(1);
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
---
<BaseLayout title="首页" description="记录 C++、嵌入式、PCB 打板与 AR 图形实践，持续整理确定性、验证链路与性能预算。" currentPath="/" searchIndex={searchIndex}>
  <section class="hero page-intro page-intro-home home-hero">    <h1><span>{homeHero.titleLines[0]}</span><br /><span>{homeHero.titleLines[1]}</span></h1>
    <p class="hero-copy hero-copy-compact leading-relaxed text-gray-500 max-w-2xl mt-4 home-hero-note">
      <span>{homeHero.noteLines[0]}</span>
      <span>{homeHero.noteLines[1]}</span>
    </p>
    <div class="hero-actions hero-actions-home gap-4 home-hero-actions">
      <a class="button button-primary" href={homeHero.primaryCta.href}>{homeHero.primaryCta.label}</a>
      <a class="button button-quiet" href="/notes">先看站内已经写下来的</a>
    </div>
  </section>

  <section class="content-block content-block-home-emphasis home-section home-section-featured">
    <div class="section-heading-row">
      <div class="section-heading">
        <p class="eyebrow">精选文章</p>
        <h2>先看这些，能更快摸到这站现在的骨架。</h2>
        <p class="section-copy">这里优先放 <code>featured: true</code> 的文章。它们不是展示位，而是现在最值得先读的几篇。</p>
      </div>
      <a class="section-link" href="/notes">去看全部笔记</a>
    </div>
    {leadFeatured && (
      <div class="feature-grid feature-grid-home feature-grid-home-hero">
        <article class="feature-card feature-card-large feature-card-lead flex flex-col h-full">
          <p class="card-kicker bg-gray-100 text-gray-600 px-2 py-1.5 rounded-md text-xs font-medium inline-block mb-3">{leadFeatured.data.featured ? "精选文章" : "最新补位"}</p>
          <h2><a href={`/notes/${leadFeatured.id}/`}>{leadFeatured.data.title}</a></h2>
          <p>{getNoteSummary(leadFeatured)}</p>
          <div class="meta-row mt-auto">
            <span>{dateFormatter.format(leadFeatured.data.date)}</span>
            <span>{leadFeatured.data.readingTime}</span>
            <span>{leadFeatured.data.category}</span>
          </div>
        </article>
        <div class="feature-stack">
          {sideFeatured.map((note) => (
            <article class="feature-card feature-card-compact flex flex-col h-full">
              <p class="card-kicker bg-gray-100 text-gray-600 px-2 py-1.5 rounded-md text-xs font-medium inline-block mb-3">{note.data.featured ? "精选文章" : "最新补位"}</p>
              <h3><a href={`/notes/${note.id}/`}>{note.data.title}</a></h3>
              <p>{getNoteSummary(note)}</p>
              <div class="meta-row mt-auto">
                <span>{dateFormatter.format(note.data.date)}</span>
                <span>{note.data.readingTime}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    )}
  </section>

  {latestNotes.length > 0 && (
    <section class="content-block content-block-home-secondary home-section home-section-latest">
      <div class="section-heading-row">
        <div class="section-heading">
          <p class="eyebrow">最新文章</p>
          <h2>新写出来的，先顺着时间落在这里。</h2>
        </div>
        <a class="section-link" href="/notes">按时间看全部笔记</a>
      </div>
      <div class="latest-list panel">
        {latestNotes.map((note) => (
          <article class="latest-item">
            <div class="latest-item-main">
              <p class="card-kicker">最新文章</p>
              <h3><a href={`/notes/${note.id}/`}>{note.data.title}</a></h3>
              <p>{getNoteSummary(note)}</p>
            </div>
            <div class="meta-row latest-item-meta">
              <span>{dateFormatter.format(note.data.date)}</span>
              <span>{note.data.readingTime}</span>
              <span>{note.data.category}</span>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="content-block content-block-home-archive home-section home-section-legacy">
    <div class="section-heading-row">
      <div class="section-heading">
        <p class="eyebrow">以前写过</p>
        <h2>过去写过的，先从原文入口慢慢收回来。</h2>
      </div>
      <a class="section-link" href="/archive">去看全部专题</a>
    </div>
    <div class="old-posts-list panel">
      {oldPosts.map((item) => (
        <article class="old-post-item">
          <div class="old-post-main">
            <p class="card-kicker">{item.label}</p>
            <h3><a href={item.href} target="_blank" rel="noreferrer">{item.title}</a></h3>
            <p>{item.summary}</p>
          </div>
          <div class="meta-row old-post-meta">
            {item.meta.map((entry) => <span>{entry}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>


