---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getNoteSummary, getPublishedNotes, getTagStats, slugifyTag } from "../../utils/content";
import { getSearchIndex } from "../../utils/search";

const allNotes = await getCollection("notes");
const notes = getPublishedNotes(allNotes);
const searchIndex = getSearchIndex(notes);
const tagStats = getTagStats(notes);
const featuredTags = tagStats.slice(0, 3).map((tag) => {
  const latestNote = notes.find((note) => note.data.tags.some((label) => slugifyTag(label) === tag.slug));

  return {
    ...tag,
    latestNote
  };
});
---
<BaseLayout title="标签检索" description="通过标签和主题簇快速定位系统、硬件与图形相关记录。" currentPath="/tags" searchIndex={searchIndex}>
  <section class="section-heading page-intro page-intro-compact">
    <p class="eyebrow">标签</p>
    <h1>先按关键词把路找出来。</h1>
    <p class="section-copy">这里的标签、数量和入口都跟着已发布笔记走。你先按词找，再进具体内容。</p>
  </section>

  <section class="content-block">
    <input class="search" data-tag-search type="search" placeholder="搜索标签：底层系统、AR、工具链..." aria-label="搜索标签" />
  </section>

  <section class="content-block">
    <div class="tag-cloud">
      {tagStats.map((tag) => (
        <a class="tag-pill" data-tag-item={tag.label.toLowerCase()} href={`/tags/${tag.slug}`}>
          {tag.label} ({tag.count})
        </a>
      ))}
    </div>
    <div class="empty-state" data-tag-empty hidden>没有匹配的标签。</div>
  </section>

  <section class="content-block">
    <div class="section-heading">
      <p class="eyebrow">常用入口</p>
      <h2>先从现在内容最多的几条线开始</h2>
    </div>
    <div class="feature-grid">
      {featuredTags.map((item) => (
        <article class="feature-card">
          <p class="card-kicker">标签</p>
          <h3><a href={`/tags/${item.slug}`}>{item.label}</a></h3>
          <p>{item.latestNote ? `现在有 ${item.count} 篇，最近一篇是《${item.latestNote.data.title}》。` : `现在有 ${item.count} 篇站内笔记。`}</p>
          {item.latestNote && <div class="meta-row"><span>{getNoteSummary(item.latestNote)}</span></div>}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
