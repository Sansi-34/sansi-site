---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getNoteSummary, getPublishedNotes, getTagStats } from "../../utils/content";
import { getSearchIndex } from "../../utils/search";

const allNotes = await getCollection("notes");
const notes = getPublishedNotes(allNotes);
const searchIndex = getSearchIndex(notes);
const tagStats = getTagStats(notes).slice(0, 8);
const latestNotes = notes.slice(0, 3);
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
const notesByYear = Object.entries(
  notes.reduce<Record<string, typeof notes>>((groups, note) => {
    const year = String(note.data.date.getFullYear());
    groups[year] ??= [];
    groups[year].push(note);
    return groups;
  }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));
---
<BaseLayout title="全部笔记" description="按发布时间顺着看 Sansi 已经写下来的全部站内笔记。" currentPath="/notes" canonicalPath="/notes/" searchIndex={searchIndex}>
  <section class="section-heading page-intro page-intro-compact">
    <p class="eyebrow">笔记</p>
    <h1>先按时间，把已经写下来的全摆出来。</h1>
    <p class="section-copy">这里不分专题，不先筛标签，就按发布时间往下看。想按问题线索找，也可以直接走标签页。</p>
  </section>

  <section class="content-block">
    <div class="tags">
      <a class="tag is-active" href="/notes">全部笔记 ({notes.length})</a>
      <a class="tag" href="/tags">去看标签</a>
      {tagStats.map((tag) => (
        <a class="tag" href={`/tags/${tag.slug}`}>{tag.label} ({tag.count})</a>
      ))}
    </div>
  </section>

  <section class="content-block notes-index-layout">
    <div class="year-groups notes-index-main">
      {notesByYear.map(([year, items]) => (
        <div class="year-group">
          <div class="year-group-head">
            <p class="year-group-label">{year}</p>
            <span class="year-group-count">{items.length} 篇</span>
          </div>
          <div class="archive-list">
            {items.map((note) => (
              <article class="archive-item">
                <div class="small-meta">{dateFormatter.format(note.data.date)}</div>
                <div>
                  <h3><a href={`/notes/${note.id}/`}>{note.data.title}</a></h3>
                  <p>{getNoteSummary(note)}</p>
                  <div class="meta-row">
                    <span>{note.data.featured ? "精选" : "已发布"}</span>
                    <span>{note.data.readingTime}</span>
                    <span>{note.data.category}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>

    <aside class="notes-sidebar">
      <div class="note-panel notes-sidebar-panel">
        <p class="card-kicker">站内状态</p>
        <h3>先从这几条线往下逛，会更顺一点。</h3>
        <p>现在站内已经有 {notes.length} 篇已发布笔记，分布在 {notesByYear.length} 个年份分组里，常用标签先收在右边。</p>
        <div class="meta-row">
          <span>{notes.length} 篇笔记</span>
          <span>{tagStats.length} 个常用标签</span>
        </div>
      </div>

      <div class="note-panel notes-sidebar-panel">
        <p class="card-kicker">最近写下的</p>
        <div class="notes-sidebar-list">
          {latestNotes.map((note) => (
            <a class="notes-sidebar-link" href={`/notes/${note.id}/`}>
              <strong>{note.data.title}</strong>
              <span>{dateFormatter.format(note.data.date)} · {note.data.readingTime}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="note-panel notes-sidebar-panel">
        <p class="card-kicker">常用标签</p>
        <div class="tag-cloud">
          {tagStats.map((tag) => (
            <a class="tag-pill" href={`/tags/${tag.slug}`}>{tag.label}</a>
          ))}
        </div>
      </div>

      <div class="note-panel notes-sidebar-panel notes-sidebar-links">
        <p class="card-kicker">换条路看</p>
        <a class="card-link" href="/archive">按专题看</a>
        <a class="card-link" href="/tags">按标签找</a>
        <a class="card-link" href="/about">先看关于</a>
      </div>
    </aside>
  </section>
</BaseLayout>
