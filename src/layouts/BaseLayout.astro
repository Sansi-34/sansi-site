---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BottomNav from "../components/BottomNav.astro";
import { siteMeta } from "../data/site";

interface Props {
  title: string;
  description: string;
  currentPath: string;
  canonicalPath?: string;
  searchIndex?: unknown[];
}

const { title, description, currentPath, canonicalPath = currentPath, searchIndex = [] } = Astro.props;
const searchPayload = JSON.stringify(searchIndex).replace(/</g, "\\u003c");
const pageTitle = `${siteMeta.titleSuffix} | ${title}`;
const canonicalUrl = new URL(canonicalPath, siteMeta.siteUrl).toString();
const ogImageUrl = new URL(siteMeta.ogImagePath, siteMeta.siteUrl).toString();
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={siteMeta.themeColor} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={siteMeta.faviconPath} />
    <link rel="alternate" type="application/rss+xml" title={`${siteMeta.name} RSS`} href="/rss.xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${siteMeta.name} 的站点分享封面`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <style is:inline>
      :root {
        background: #fafafa;
        color: #171717;
      }

      html,
      body {
        background: #fafafa;
        color: #171717;
      }

      html[data-theme="dark"],
      html[data-theme="dark"] body {
        background: #0f1115;
        color: #f3f4f6;
      }
    </style>
    <script is:inline>
      (() => {
        try {
          const storageKey = "sansi-theme-mode";
          const stored = localStorage.getItem(storageKey);
          const mode = stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
          const media = window.matchMedia ? window.matchMedia("(prefers-color-scheme: dark)") : null;
          const theme = mode === "system" ? (media && media.matches ? "dark" : "light") : mode;
          const root = document.documentElement;
          root.setAttribute("data-theme-mode", mode);
          root.setAttribute("data-theme", theme);
        } catch {
          document.documentElement.setAttribute("data-theme-mode", "system");
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main class="page-shell">
      <slot />
      <Footer />
    </main>
    <BottomNav currentPath={currentPath} />
    <script is:inline define:vars={{ searchPayload }}>
      window.__SANSI_SEARCH__ = JSON.parse(searchPayload);
    </script>
    <script is:inline src="/assets/site.js"></script>
  </body>
</html>
